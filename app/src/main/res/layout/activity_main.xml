<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp" />

    <!-- Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardElevation="16dp"
        app:cardCornerRadius="0dp"
        android:backgroundTint="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHome"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_dashboard" app:tint="@color/nav_active"/>
                <TextView style="@style/NavText" android:text="Home" android:textColor="@color/nav_active"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAbsensi"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_absensi" app:tint="@color/nav_inactive"/>
                <TextView style="@style/NavText" android:text="Absensi" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navApproval"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_izin" app:tint="@color/nav_inactive"/>
                <TextView style="@style/NavText" android:text="Approval" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navKaryawan"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_users" app:tint="@color/nav_inactive"/>
                <TextView style="@style/NavText" android:text="Karyawan" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSettings"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_settings" app:tint="@color/nav_inactive"/>
                <TextView style="@style/NavText" android:text="Setelan" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfil"
                style="@style/NavItem"
                android:clickable="true"
                android:focusable="true">
                <ImageView style="@style/NavIcon" android:src="@drawable/ic_history" app:tint="@color/nav_inactive"/>
                <TextView style="@style/NavText" android:text="Profil" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
