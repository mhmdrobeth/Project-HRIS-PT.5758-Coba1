<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengajuan Izin / Cuti"
            android:textColor="@color/primary_m2"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipe Pengajuan"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerLeaveType"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/leave_types"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_search_input"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Mulai"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Pilih Tanggal Mulai"
                    android:focusable="false"
                    android:clickable="true"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_search_input"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Selesai"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Pilih Tanggal Selesai"
                    android:focusable="false"
                    android:clickable="true"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_search_input"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alasan Pengajuan"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:hint="Tuliskan alasan pengajuan Anda..."
                    android:gravity="top"
                    android:padding="16dp"
                    android:background="@drawable/bg_search_input"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitLeave"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Kirim Pengajuan"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/primary_m2"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/btnViewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lihat Status Pengajuan Saya"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:textColor="@color/primary_m2"
            android:textStyle="bold"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
